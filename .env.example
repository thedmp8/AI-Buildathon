OPENAI_API_KEY=sk-your-api-key-here

# Optional: model used by the small follow-up chat box.
OPENAI_MODEL=gpt-5.5

# Optional: model used by the exchange assessment report.
# This endpoint uses the Responses API web_search tool.
OPENAI_ASSESSMENT_MODEL=gpt-5

# Optional: override the follow-up chat behaviour.
OPENAI_INSTRUCTIONS=You are a helpful assistant embedded in a simple website. Keep answers concise and practical.
